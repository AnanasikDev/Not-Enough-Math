{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-debug-log",
            "displayName": "Debug Log",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ANEM_ERR_LOG": "ON",
                "ANEM_ERR_THROW": "OFF",
                "ANEM_ERR_USE_NAN": "ON"
            }
        },
        {
            "name": "windows-debug-throw",
            "displayName": "Debug Throw",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ANEM_ERR_LOG": "ON",
                "ANEM_ERR_THROW": "ON",
                "ANEM_ERR_USE_NAN": "ON"
            }
        },
        {
            "name": "windows-release-fast",
            "displayName": "Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ANEM_ERR_LOG": "OFF",
                "ANEM_ERR_THROW": "OFF",
                "ANEM_ERR_USE_NAN": "OFF"
            }
        }
    ]
}